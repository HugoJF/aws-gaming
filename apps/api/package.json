{
  "name": "@aws-gaming/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:lambda": "rm -rf .lambda && mkdir -p .lambda dist && bun build src/index.ts --target=node --format=esm --outfile .lambda/index.mjs && (cd .lambda && zip -q -r ../dist/lambda.zip index.mjs)",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo 'No tests yet for @aws-gaming/api'"
  },
  "dependencies": {
    "@aws-gaming/auth-links": "workspace:*",
    "@aws-gaming/aws-control": "workspace:*",
    "@aws-gaming/contracts": "workspace:*",
    "@aws-sdk/client-auto-scaling": "^3.988.0",
    "@aws-sdk/client-ec2": "^3.988.0",
    "@aws-sdk/client-dynamodb": "^3.988.0",
    "@aws-sdk/client-efs": "^3.988.0",
    "@aws-sdk/client-pricing": "^3.988.0",
    "@aws-sdk/client-resource-groups-tagging-api": "^3.988.0",
    "@aws-sdk/lib-dynamodb": "^3.988.0",
    "gamedig": "^5.3.2",
    "hono": "^4.8.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147"
  }
}
